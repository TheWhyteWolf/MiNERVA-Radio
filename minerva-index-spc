#!/bin/bash

# --- CONFIGURATION ---
WORK_DIR="${1:-.}"
OUTPUT_CSV="$WORK_DIR/vgm_catalogue.csv"

echo "Indexing: $WORK_DIR"
echo "Output:   $OUTPUT_CSV"
echo "------------------------------------------"

# Write CSV header
echo "TLD_ID,SUB_ID,PLATFORM_ID,FILE_ID,Catalogue_ID,TLD_Name,Platform_Name,Game_Name,File_Name" > "$OUTPUT_CSV"

tld_id=100
sub_id=1000
total_tracks=0
total_subdirs=0
total_tlds=0

# Excluded folders
excluded="cli-visualizer|clivisualizer|libvgm|build|__MACOSX|Xtract|DeAccent|indexer|Loose"

# File extensions pattern (vgm, vgz, spc)
FILE_PATTERN="\( -name \"*.vgz\" -o -name \"*.vgm\" -o -name \"*.spc\" \)"

# Function to find audio files in a directory
find_audio_files() {
    local dir="$1"
    local depth="${2:--1}"
    if [ "$depth" -eq -1 ]; then
        find "$dir" -type f \( -name "*.vgz" -o -name "*.vgm" -o -name "*.spc" \)
    else
        find "$dir" -maxdepth "$depth" -type f \( -name "*.vgz" -o -name "*.vgm" -o -name "*.spc" \)
    fi
}

# Function to resolve platform name for a given TLD and optional platform subdir
resolve_platform_name() {
    local tld_name="$1"
    local subdir_name="$2"
    case "${tld_name^^}" in
        SNES|"SUPER NINTENDO") echo "SNES" ;;
        *) echo "$subdir_name" ;;
    esac
}

# Function to check if a folder is a developer/platform folder
# Returns 0 (true) if it contains subdirs but no direct audio files
is_platform_folder() {
    local dir="$1"
    local has_files
    local has_dirs
    has_files=$(find_audio_files "$dir" 1 | head -1)
    has_dirs=$(find "$dir" -maxdepth 1 -mindepth 1 -type d | head -1)
    if [ -z "$has_files" ] && [ -n "$has_dirs" ]; then
        return 0
    fi
    return 1
}

# Find all top level directories
mapfile -t tlds < <(find "$WORK_DIR" -maxdepth 1 -mindepth 1 -type d | \
    grep -vE "$excluded" | \
    sort)

for tld in "${tlds[@]}"; do
    tld_name=$(basename "$tld")
    echo "TLD: $tld_name ($tld_id)"
    ((total_tlds++))

    platform_id=1

    # Get all direct subdirs of TLD
    mapfile -t subdirs < <(find "$tld" -maxdepth 1 -mindepth 1 -type d | sort)

    for subdir in "${subdirs[@]}"; do
        subdir_name=$(basename "$subdir")

        if is_platform_folder "$subdir"; then
            # This is a developer/platform folder — go one level deeper
            platform_name=$(resolve_platform_name "$tld_name" "$subdir_name")
            echo "  Platform: $subdir_name ($platform_name)"
            mapfile -t games < <(find "$subdir" -maxdepth 1 -mindepth 1 -type d | sort)

            for game in "${games[@]}"; do
                game_name=$(basename "$game")
                file_id=1

                mapfile -t files < <(find_audio_files "$game" | sort)

                if [ ${#files[@]} -eq 0 ]; then
                    continue
                fi

                ((total_subdirs++))

                for file in "${files[@]}"; do
                    file_name=$(basename "$file")
                    cat_id="${tld_id}-${sub_id}-${file_id}"

                    echo "${tld_id},${sub_id},${platform_id},${file_id},\"${cat_id}\",\"${tld_name}\",\"${platform_name}\",\"${game_name}\",\"${file_name}\"" >> "$OUTPUT_CSV"

                    ((file_id++))
                    ((total_tracks++))
                done

                ((sub_id++))
            done

            ((platform_id++))
        else
            # This is a game folder directly
            platform_name=$(resolve_platform_name "$tld_name" "")
            file_id=1

            mapfile -t files < <(find_audio_files "$subdir" | sort)

            if [ ${#files[@]} -eq 0 ]; then
                continue
            fi

            ((total_subdirs++))

            for file in "${files[@]}"; do
                file_name=$(basename "$file")
                cat_id="${tld_id}-${sub_id}-${file_id}"

                echo "${tld_id},${sub_id},0,${file_id},\"${cat_id}\",\"${tld_name}\",\"${platform_name}\",\"${subdir_name}\",\"${file_name}\"" >> "$OUTPUT_CSV"

                ((file_id++))
                ((total_tracks++))
            done

            ((sub_id++))
        fi
    done

    ((tld_id++))
done

echo "------------------------------------------"
echo "TLDs:    $total_tlds"
echo "SubDirs: $total_subdirs"
echo "Tracks:  $total_tracks"
echo "Written: $OUTPUT_CSV"
echo "Done."
