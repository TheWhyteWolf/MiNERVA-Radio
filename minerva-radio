#!/bin/bash
# =============================================================================
# minerva-radio — MiNERVA Radio main engine
# =============================================================================

CONFIG_FILE="$HOME/.config/minerva-radio/minerva.conf"
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
else
    echo -e "\e[1;31mError:\e[0m No config found. Run 'minerva-setup' first."
    exit 1
fi

export SCRIPT_DIR=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
export CSV_FILE="${VGM_DIR}/${CATALOGUE_NAME}.csv"
export VGM_DIR="$VGM_DIR"
export VIS_PATH="/usr/bin/vis"
export VIS_CONFIG="$HOME/.config/vis/config"
export QUEUE_FILE="/tmp/minerva_queue"
export DEBUG_LOG="/tmp/minerva_debug.log"
GOVERNOR_BACKUP=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor)
SCHEMES=($COLOUR_SCHEMES)
CHARS=("#" "|" ":" "+" "*" "=" "!" ">" "%" "@" "^" "~" "-" "o" "x")

# --- CSV FIELD PARSER ---
parse_entry() {
    local entry="$1"
    mapfile -t fields < <(echo "$entry" | python3 -c "
import sys, csv
r = list(csv.reader([sys.stdin.read()]))[0]
for f in [r[4], r[5], r[6], r[7], r[8]]:
    print(f)
")
    CAT_ID="${fields[0]}"
    TLD="${fields[1]}"
    PLATFORM="${fields[2]}"
    GAME="${fields[3]}"
    FILE="${fields[4]}"
}

# --- SETUP ---
setup() {
    random_scheme="${SCHEMES[$RANDOM % ${#SCHEMES[@]}]}"
    random_char="${CHARS[$RANDOM % ${#CHARS[@]}]}"
    mkdir -p "$(dirname "$VIS_CONFIG")"
    cat > "$VIS_CONFIG" <<EOF
audio.sources=pulse
audio.pulse.source=minerva_radio.monitor
visualizer.fps=45
audio.stereo.enabled=true
visualizer.scaling.multiplier=3.5
visualizer.spectrum.character=$random_char
visualizers=spectrum
colors.override.terminal=false
colors.scheme=$random_scheme
EOF

    existing=$(pactl list modules short | grep "module-null-sink" | grep "minerva_radio" | awk '{print $1}')
    if [ -n "$existing" ]; then
        pactl unload-module "$existing" 2>/dev/null
    fi
    pactl load-module module-null-sink sink_name=minerva_radio sink_properties=device.description=MiNERVA_Radio
    pactl suspend-sink minerva_radio 0

    > "$QUEUE_FILE"
    > "$DEBUG_LOG"
}

# --- CLEANUP ---
cleanup() {
    echo "$GOVERNOR_BACKUP" | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
    existing=$(pactl list modules short | grep "module-null-sink" | grep "minerva_radio" | awk '{print $1}')
    if [ -n "$existing" ]; then
        pactl unload-module "$existing" 2>/dev/null
    fi
    rm -f "$QUEUE_FILE"
    rm -f "$DEBUG_LOG"
    tmux kill-session -t minerva_radio 2>/dev/null
    exit
}

# --- LOOKUP BY CATALOGUE ID ---
lookup_by_id() {
    local cat_id="$1"
    python3 -c "
import sys, csv
with open('$CSV_FILE', newline='') as f:
    for row in csv.reader(f):
        if len(row) >= 9 and row[4] == '$cat_id':
            print(','.join('\"' + c + '\"' if ',' in c else c for c in row))
            break
"
}

# --- THE PLAYER ENGINE ---
if [ "$1" == "--run-engine" ]; then
    SCHEMES=($COLOUR_SCHEMES)
    CHARS=("#" "|" ":" "+" "*" "=" "!" ">" "%" "@" "^" "~" "-" "o" "x")

    while true; do
        echo "$(date): Queue check - $(wc -l < $QUEUE_FILE 2>/dev/null || echo 0) entries" >> "$DEBUG_LOG"
        echo "$(date): Queue contents: $(cat $QUEUE_FILE 2>/dev/null || echo empty)" >> "$DEBUG_LOG"

        if [ -s "$QUEUE_FILE" ]; then
            cat_id=$(head -1 "$QUEUE_FILE")
            echo "$(date): Playing from queue - $cat_id" >> "$DEBUG_LOG"
            sed -i '1d' "$QUEUE_FILE"
            random_entry=$(lookup_by_id "$cat_id")
            if [ -z "$random_entry" ]; then
                echo "$(date): ERROR - ID $cat_id not found in CSV" >> "$DEBUG_LOG"
                echo -e "\e[1;31m[ QUEUE ERROR ]\e[0m Catalogue ID $cat_id not found, skipping."
                sleep 2
                continue
            fi
            source="REQUEST"
        else
            echo "$(date): Queue empty, playing random" >> "$DEBUG_LOG"
            random_entry=$(tail -n +2 "$CSV_FILE" | shuf -n 1)
            source="RANDOM"
        fi

        parse_entry "$random_entry"

        if [ -n "$PLATFORM" ]; then
            file_path="$VGM_DIR/$TLD/$PLATFORM/$GAME/$FILE"
        else
            file_path="$VGM_DIR/$TLD/$GAME/$FILE"
        fi

        echo "$(date): Now playing - $CAT_ID / $file_path" >> "$DEBUG_LOG"

        random_scheme="${SCHEMES[$RANDOM % ${#SCHEMES[@]}]}"
        random_char="${CHARS[$RANDOM % ${#CHARS[@]}]}"
        sed -i "s/^colors.scheme=.*/colors.scheme=$random_scheme/" "$VIS_CONFIG"
        sed -i "s/^visualizer.spectrum.character=.*/visualizer.spectrum.character=$random_char/" "$VIS_CONFIG"
        tmux send-keys -t minerva_radio:0.1 "r" "" 2>/dev/null

        clear
        echo -e "\e[1;34m[ NOW PLAYING ]\e[0m \e[1;33m[$source]\e[0m"
        echo -e "\e[1;32mID:     \e[0m $CAT_ID"
        if [ -n "$PLATFORM" ]; then
            echo -e "\e[1;32mSystem: \e[0m $PLATFORM"
        fi
        echo -e "\e[1;32mGame:   \e[0m $(echo "$GAME" | tr '_' ' ')"
        echo -e "\e[1;32mTrack:  \e[0m $FILE"
        echo -e "\e[1;32mColour: \e[0m $random_scheme"

        if [ -s "$QUEUE_FILE" ]; then
            queue_depth=$(wc -l < "$QUEUE_FILE")
            echo -e "\e[1;35mQueue:  \e[0m $queue_depth track(s) waiting"
        fi

        echo "------------------------------------------"
        case "${FILE,,}" in
            *.vgm|*.vgz)
                PULSE_SINK=minerva_radio vgmplayer "$file_path"
                ;;
            *.mod|*.mp3|*.flac|*.wav|*.spc)
                PULSE_SINK=minerva_radio mpv --no-video --really-quiet --af=loudnorm=I=-14 "$file_path"
                ;;
        esac
    done
    exit
fi

# --- THE LAUNCHER LOGIC ---
if [ ! -f "$CSV_FILE" ]; then
    echo -e "\e[1;31mError:\e[0m Catalogue not found at $CSV_FILE"
    echo "Run '$DEFAULT_INDEXER \"$VGM_DIR\"' to build it first."
    exit 1
fi

trap cleanup SIGINT SIGTERM

if [[ "$USE_PERFORMANCE_GOV" == "true" ]]; then
    echo "performance" | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
fi

setup

tmux kill-session -t minerva_radio 2>/dev/null
tmux new-session -d -s minerva_radio -c "$VGM_DIR" "$0 --run-engine"

sleep 3

tmux split-window -v -t minerva_radio "$VIS_PATH"
tmux resize-pane -t minerva_radio:0.0 -y 12

sleep 2
tmux send-keys -t minerva_radio:0.1 "r" ""

tmux attach-session -t minerva_radio
cleanup
