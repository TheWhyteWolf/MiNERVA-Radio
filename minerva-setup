#!/bin/bash
# =============================================================================
# minerva-setup — MiNERVA Radio first-run configuration wizard
# =============================================================================

CONFIG_DIR="$HOME/.config/minerva-radio"
CONFIG_FILE="$CONFIG_DIR/minerva.conf"

GREEN="\e[1;32m"
CYAN="\e[1;36m"
YELLOW="\e[1;33m"
RED="\e[1;31m"
RESET="\e[0m"

print_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════╗${RESET}"
    echo -e "${CYAN}║        MiNERVA RADIO SETUP WIZARD        ║${RESET}"
    echo -e "${CYAN}╚══════════════════════════════════════════╝${RESET}"
    echo ""
}

ask() {
    local prompt="$1" default="$2" response
    echo -en "${GREEN}▶ ${RESET}${prompt}"
    [[ -n "$default" ]] && echo -en " ${YELLOW}[${default}]${RESET}"
    echo -en ": "
    read -r response
    echo "${response:-$default}"
}

check_deps() {
    echo -e "${CYAN}Checking dependencies...${RESET}"
    echo ""
    local all_ok=true

    echo -e "  ${YELLOW}Required:${RESET}"
    for cmd in tmux mpv python3 pactl; do
        if command -v "$cmd" &>/dev/null; then
            echo -e "    ${GREEN}✔${RESET} $cmd"
        else
            echo -e "    ${RED}✗${RESET} $cmd ${RED}(not found — required)${RESET}"
            all_ok=false
        fi
    done

    echo ""
    echo -e "  ${YELLOW}Optional:${RESET}"
    for cmd in vis ffprobe vgmplayer unrar curl; do
        if command -v "$cmd" &>/dev/null; then
            echo -e "    ${GREEN}✔${RESET} $cmd"
        else
            echo -e "    ${YELLOW}~${RESET} $cmd ${YELLOW}(not found)${RESET}"
        fi
    done

    echo ""
    if [[ "$all_ok" == "false" ]]; then
        echo -e "${RED}⚠ One or more required dependencies are missing.${RESET}"
        echo -e "  Install them via pacman or the AUR before running minerva-radio."
        echo ""
        echo -en "  Continue setup anyway? [y/N]: "
        read -rsn1 cont
        echo ""
        [[ "$cont" != "y" && "$cont" != "Y" ]] && echo "Exiting." && exit 1
    fi
}

# --- Already configured? ---
if [[ -f "$CONFIG_FILE" ]]; then
    print_header
    echo -e "A config already exists at ${CYAN}$CONFIG_FILE${RESET}"
    echo ""
    echo -e "  ${GREEN}1.${RESET} View current config"
    echo -e "  ${GREEN}2.${RESET} Re-run setup (overwrite)"
    echo -e "  ${GREEN}q.${RESET} Quit"
    echo ""
    echo -n "> "
    read -rsn1 choice
    echo ""
    case "$choice" in
        1)
            echo ""
            cat "$CONFIG_FILE"
            echo ""
            echo -e "\e[1;33mPress any key to exit...\e[0m"
            read -rsn1
            exit 0
            ;;
        2) ;;
        *) exit 0 ;;
    esac
fi

print_header
echo -e "Welcome to MiNERVA Radio! This wizard will configure your setup."
echo -e "Press ${YELLOW}Enter${RESET} to accept defaults shown in brackets."
echo ""
check_deps

# --- Music directory ---
print_header
echo -e "${CYAN}[ STEP 1 of 5 — Music Directory ]${RESET}"
echo ""
VGM_DIR=$(ask "Path to your VGM music directory" "$HOME/Music/VGM")
while [[ ! -d "$VGM_DIR" ]]; do
    echo ""
    echo -en "  ${YELLOW}⚠ Directory not found. Create it? [Y/n]:${RESET} "
    read -rsn1 mk
    echo ""
    if [[ "$mk" != "n" && "$mk" != "N" ]]; then
        mkdir -p "$VGM_DIR" && echo -e "  ${GREEN}✔ Created: $VGM_DIR${RESET}" && break
    else
        VGM_DIR=$(ask "Path to your VGM music directory" "$HOME/Music/VGM")
    fi
done

# --- Catalogue name ---
print_header
echo -e "${CYAN}[ STEP 2 of 5 — Catalogue Name ]${RESET}"
echo ""
echo -e "  This is the name of the CSV file your indexer will generate."
echo -e "  It will be saved inside your music directory."
echo ""
CATALOGUE_NAME=$(ask "Catalogue filename (without extension)" "vgmcatalogue")

# --- Indexer preference ---
print_header
echo -e "${CYAN}[ STEP 3 of 5 — Default Indexer ]${RESET}"
echo ""
echo -e "  ${GREEN}1.${RESET} minerva-index       — VGM + MP3/FLAC/WAV + ffprobe metadata ${YELLOW}[recommended]${RESET}"
echo -e "  ${GREEN}2.${RESET} minerva-index-spc   — VGM + SPC files"
echo -e "  ${GREEN}3.${RESET} minerva-index-basic — VGM/VGZ only"
echo ""
echo -n "> "
read -rsn1 idx_choice
echo ""
case "$idx_choice" in
    2) DEFAULT_INDEXER="minerva-index-spc" ;;
    3) DEFAULT_INDEXER="minerva-index-basic" ;;
    *)  DEFAULT_INDEXER="minerva-index" ;;
esac
echo -e "  ${GREEN}✔${RESET} Selected: $DEFAULT_INDEXER"

# --- Colour schemes ---
print_header
echo -e "${CYAN}[ STEP 4 of 5 — Visualiser Colour Schemes ]${RESET}"
echo ""
echo -e "  These are cycled randomly with each new track."
echo -e "  Available: gameboy gameboy_pocket bbc_micro pico8 cga nes minerva c64 zx_spectrum"
echo ""
read -r -e -i "gameboy gameboy_pocket bbc_micro pico8 cga nes minerva c64 zx_spectrum" COLOUR_SCHEMES
[[ -z "$COLOUR_SCHEMES" ]] && COLOUR_SCHEMES="gameboy gameboy_pocket bbc_micro pico8 cga nes minerva c64 zx_spectrum"

# --- CPU governor ---
print_header
echo -e "${CYAN}[ STEP 5 of 5 — CPU Performance Mode ]${RESET}"
echo ""
echo -e "  When enabled, minerva-radio sets your CPU governor to ${YELLOW}performance${RESET}"
echo -e "  while the station is running, and restores it on exit."
echo -e "  This requires ${YELLOW}sudo${RESET} and is recommended for smooth VGM playback."
echo ""
echo -en "${GREEN}▶ ${RESET}Enable CPU performance mode? ${YELLOW}[Y/n]${RESET}: "
read -rsn1 gov_choice
echo ""
USE_PERFORMANCE_GOV="true"
[[ "$gov_choice" == "n" || "$gov_choice" == "N" ]] && USE_PERFORMANCE_GOV="false"
echo -e "  ${GREEN}✔${RESET} CPU performance mode: $USE_PERFORMANCE_GOV"

# --- Write config ---
mkdir -p "$CONFIG_DIR"
cat > "$CONFIG_FILE" <<EOF
# MiNERVA Radio configuration
# Generated by minerva-setup on $(date)

VGM_DIR="$VGM_DIR"
CATALOGUE_NAME="$CATALOGUE_NAME"
DEFAULT_INDEXER="$DEFAULT_INDEXER"
COLOUR_SCHEMES="$COLOUR_SCHEMES"
USE_PERFORMANCE_GOV="$USE_PERFORMANCE_GOV"
EOF

# --- Done ---
print_header
echo -e "${CYAN}╔══════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}║           SETUP COMPLETE  ✔              ║${RESET}"
echo -e "${CYAN}╚══════════════════════════════════════════╝${RESET}"
echo ""
echo -e "  Config saved to: ${CYAN}$CONFIG_FILE${RESET}"
echo ""
echo -e "  ${YELLOW}Your settings:${RESET}"
echo -e "  ${GREEN}Music directory:${RESET}  $VGM_DIR"
echo -e "  ${GREEN}Catalogue name:${RESET}   $CATALOGUE_NAME.csv"
echo -e "  ${GREEN}Default indexer:${RESET}  $DEFAULT_INDEXER"
echo -e "  ${GREEN}Colour schemes:${RESET}   $COLOUR_SCHEMES"
echo -e "  ${GREEN}Performance mode:${RESET} $USE_PERFORMANCE_GOV"
echo ""
echo -e "  ${YELLOW}Next steps:${RESET}"
echo -e "  ${GREEN}1.${RESET} Build your catalogue:"
echo -e "     ${CYAN}$DEFAULT_INDEXER \"$VGM_DIR\"${RESET}"
echo ""
echo -e "  ${GREEN}2.${RESET} Start the radio:"
echo -e "     ${CYAN}minerva-radio${RESET}"
echo ""
echo -e "  ${GREEN}3.${RESET} In another terminal, request tracks:"
echo -e "     ${CYAN}minerva-request${RESET}"
echo ""
echo -e "  ${GREEN}4.${RESET} To reconfigure at any time:"
echo -e "     ${CYAN}minerva-setup${RESET}"
echo ""
